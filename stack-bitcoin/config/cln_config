# CLN Node General Info
rgb=0399b5
network=bitcoin

# CLN REST API
clnrest-port=3001
clnrest-host=0.0.0.0
clnrest-protocol=http

# Bitcoin RPC config (if not using trustedcoin plugin)
bitcoin-rpcuser=bitcoind.user
bitcoin-rpcpassword=bitcoind.pass
bitcoin-rpcconnect=10.0.0.12

# Autoclean config (1 week in seconds, 1 month for expired invoices)
autoclean-failedpays-age=604800
autoclean-failedforwards-age=604800
autoclean-expiredinvoices-age=2592000

# Backup config (native replication or backup plugin, use one of the following lines)
wallet=sqlite3:///root/.lightning/bitcoin/lightningd.sqlite3:/backup_usb/lightningd.sqlite3
# important-plugin=/usr/local/bin/backup/backup.py

# Plugins config (careful CLBOSS can open channels and manage funds, so only use if you trust it)
plugin=/usr/local/bin/clboss

# Use trustedcoin for both worlds, it uses bitcoind if available (helps with pruned bitcoind)
disable-plugin=bcli
important-plugin=/usr/local/bin/trustedcoin
important-plugin=/usr/local/bin/watchtower-client

# Network and proxy settings (Tor in this case)
bind-addr=0.0.0.0:9735
proxy=10.0.0.11:9050
addr=statictor:10.0.0.11:9051
always-use-proxy=true